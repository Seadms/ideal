# ── Database ──────────────────────────────────────────────────────────────────
# Turso database (cloud deployment)
# Create a free database at https://turso.tech
# Then: turso db show <name> --url  and  turso db tokens create <name>
TURSO_DATABASE_URL=libsql://your-db-name-your-account.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
# Leave both unset for local development — app uses data/life.db instead

# ── Push notifications (optional) ─────────────────────────────────────────────
# Generate a key pair once with:  npx web-push generate-vapid-keys
# Without these, push notifications are disabled (the rest of the app still works).
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# Shared secret the Vercel cron (/api/push-notify, see vercel.json) must present
# as `Authorization: Bearer <CRON_SECRET>`. If unset, the endpoint is unauthenticated.
CRON_SECRET=your-random-cron-secret

# ── AI bonus-task suggestions (optional) ──────────────────────────────────────
# Google Gemini API key. When unset, the daily bonus task falls back to a
# built-in pool of suggestions. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
