# Turso database (cloud deployment)
# Create a free database at https://turso.tech
# Then: turso db show <name> --url  and  turso db tokens create <name>
TURSO_DATABASE_URL=libsql://your-db-name-your-account.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Leave both unset for local development — app uses data/life.db instead
